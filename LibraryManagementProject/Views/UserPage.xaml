<Page x:Class="LibraryManagementProject.Views.UserPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#ECF0F1">


    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="400"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <StackPanel Orientation="Horizontal" Grid.Column="0" Grid.Row="0" Margin="8">

            <TextBlock Text="Status:"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>

            <ComboBox x:Name="cbFilterStatus"
                  Width="150"
                  SelectionChanged="cbFilterStatus_SelectionChanged">

                <ComboBoxItem Content="All" IsSelected="True"/>
                <ComboBoxItem Content="Active"/>
                <ComboBoxItem Content="Inactive"/>

            </ComboBox>
        </StackPanel>


        <ListView x:Name="lvUsers"
                  Grid.Column="0"
                  Grid.Row="1"
                  Margin="0,0,15,0"
                  SelectionChanged="lvUsers_SelectionChanged">

            <ListView.View>

                <GridView>


                    <GridViewColumn Header="ID"
                                    Width="50"
                                    DisplayMemberBinding="{Binding UserId}"/>


                    <GridViewColumn Header="Username"
                                    Width="140"
                                    DisplayMemberBinding="{Binding Username}"/>


                    <GridViewColumn Header="Full Name"
                                    Width="180"
                                    DisplayMemberBinding="{Binding FullName}"/>


                    <GridViewColumn Header="Role"
                                    Width="120"
                                    DisplayMemberBinding="{Binding Role.RoleName}"/>


                    <GridViewColumn Header="Status"
                                    Width="100"
                                    DisplayMemberBinding="{Binding StatusText}"/>


                </GridView>

            </ListView.View>

        </ListView>

        <Border Grid.Column="2"
                Grid.Row="1"
                Background="White"
                Padding="15">


            <StackPanel>

                <Label Content="User Information"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

                <Label Content="Username"
                       Margin="0,15,0,0"/>

                <TextBox x:Name="txtUsername"
                         IsReadOnly="True"/>

                <Label Content="Full Name"
                       Margin="0,10,0,0"/>

                <TextBox x:Name="txtFullName"
                         IsReadOnly="True"/>

                <Label Content="Role"
                       Margin="0,10,0,0"/>

                <ComboBox x:Name="cbRole"/>



                <Label Content="Status"
                       Margin="0,10,0,0"/>

                <ComboBox x:Name="cbStatus"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,25,0,0">

                    <Button x:Name="btnUpdate"
                            Content="Update"
                            Width="100"
                            Height="35"
                            Click="btnUpdate_Click"/>


                    <Button x:Name="btnCreate"
                            Content="Create User"
                            Width="100"
                            Height="35"
                            Margin="15,0,0,0"
                            Click="btnCreate_Click"/>

                </StackPanel>

            </StackPanel>


        </Border>


    </Grid>


</Page>
<Window x:Class="LibraryManagementProject.Views.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Dashboard"
        Width="1200"
        Height="700"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <Border Height="60"
                DockPanel.Dock="Top"
                Background="#1565C0">

            <TextBlock Text="Library Management System"
                Foreground="White"
                FontSize="24"
                FontWeight="Bold"
                VerticalAlignment="Center"
                Margin="20"/>
        </Border>

        <StackPanel DockPanel.Dock="Left"
            Width="220"
            Background="#EEEEEE">

            <Button Content="Dashboard" Margin="10"/>
            <Button Content="Books" Margin="10"/>
            <Button Content="Authors" Margin="10"/>
            <Button Content="Categories" Margin="10"/>
            <Button Content="Members" Margin="10"/>
            <Button Content="Borrow" Margin="10"/>
            <Button Content="Logout" Margin="10"/>

        </StackPanel>

        <Grid>

            <StackPanel Margin="30">

                <TextBlock Text="Welcome Admin"
                    FontSize="28"
                    FontWeight="Bold"/>

                <WrapPanel Margin="0,30">

                    <Border Width="220"
                            Height="120"
                            Margin="10"
                            Background="#BBDEFB">

                        <StackPanel VerticalAlignment="Center">

                            <TextBlock
                                Text="Books"
                                FontSize="22"
                                HorizontalAlignment="Center"/>

                            <TextBlock
                                Text="200"
                                FontSize="40"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"/>

                        </StackPanel>

                    </Border>

                    <Border Width="220" Height="120" Margin="10"
                            Background="#C8E6C9">

                        <StackPanel VerticalAlignment="Center">

                            <TextBlock
                                Text="Members"
                                FontSize="22"
                                HorizontalAlignment="Center"/>

                            <TextBlock
                                Text="150"
                                FontSize="40"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"/>

                        </StackPanel>

                    </Border>

                    <Border Width="220"
                            Height="120"
                            Margin="10"
                            Background="#FFE082">

                        <StackPanel VerticalAlignment="Center">

                            <TextBlock
                                Text="Borrowing"
                                FontSize="22"
                                HorizontalAlignment="Center"/>

                            <TextBlock
                                Text="35"
                                FontSize="40"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"/>

                        </StackPanel>

                    </Border>

                </WrapPanel>

            </StackPanel>

        </Grid>

    </DockPanel>

</Window>
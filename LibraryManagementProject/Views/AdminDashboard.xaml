<Page x:Class="LibraryManagementProject.Views.AdminDashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#ECF0F1">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Welcome Admin"
                   FontSize="30"
                   FontWeight="Bold"/>

        <UniformGrid Grid.Row="1"
                     Columns="4"
                     Margin="0,30,0,20">

            <Border Margin="10"
                    Background="#3498DB"
                    CornerRadius="10">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="Books"
                               Foreground="White"
                               FontSize="20"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="txtTotalBooks"
                               Foreground="White"
                               FontSize="42"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

            <Border Margin="10"
                    Background="#27AE60"
                    CornerRadius="10">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="Members"
                               Foreground="White"
                               FontSize="20"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="txtTotalMembers"
                               Foreground="White"
                               FontSize="42"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

            <Border Margin="10"
                    Background="#F39C12"
                    CornerRadius="10">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="Borrowing"
                               Foreground="White"
                               FontSize="20"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="txtTotalBorrows"
                               Foreground="White"
                               FontSize="42"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

            <Border Margin="10"
                    Background="#E74C3C"
                    CornerRadius="10">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="Users"
                               Foreground="White"
                               FontSize="20"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="txtTotalUsers"
                               Foreground="White"
                               FontSize="42"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

        </UniformGrid>

  

    </Grid>

</Page>
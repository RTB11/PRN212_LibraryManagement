<Page x:Class="LibraryManagementProject.Views.LibrarianDashboard"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LibraryManagementProject.Views"
      mc:Ignorable="d" 
      Title="LibrarianDashboard"
      Background="#ECF0F1">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                  x:Name="txtWelcome"
                 FontSize="30"
                 FontWeight="Bold"/>

        <UniformGrid Grid.Row="1"
                   Columns="3"
                   Margin="0,30,0,20">

            <Border Margin="10"
                  Background="#3498DB"
                  CornerRadius="10">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="Books"
                             Foreground="White"
                             FontSize="20"
                             HorizontalAlignment="Center"/>

                    <TextBlock x:Name="txtTotalBooks"
                             Foreground="White"
                             FontSize="42"
                             FontWeight="Bold"
                             HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

            <Border Margin="10"
                  Background="#27AE60"
                  CornerRadius="10">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="Members"
                             Foreground="White"
                             FontSize="20"
                             HorizontalAlignment="Center"/>

                    <TextBlock x:Name="txtTotalMembers"
                             Foreground="White"
                             FontSize="42"
                             FontWeight="Bold"
                             HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

            <Border Margin="10"
                  Background="#F39C12"
                  CornerRadius="10">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="Borrowing"
                             Foreground="White"
                             FontSize="20"
                             HorizontalAlignment="Center"/>

                    <TextBlock x:Name="txtTotalBorrows"
                             Foreground="White"
                             FontSize="42"
                             FontWeight="Bold"
                             HorizontalAlignment="Center"/>

                </StackPanel>

            </Border>

        </UniformGrid>



    </Grid>
</Page>

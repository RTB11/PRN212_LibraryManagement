<Page x:Class="LibraryManagementProject.Views.BorrowBookPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        d:Height="900"
        d:Width="750"
        mc:Ignorable="d"
      Background="#ECF0F1">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="300"/>
                <RowDefinition Height="300"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <TextBlock Text="Borrow Book"
                   FontSize="28"
                   FontWeight="Bold"/>

            <GroupBox Header="Member"
                      Grid.Row="1"
                      Margin="0,20,0,10">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">

                        <TextBox x:Name="txtMemberKeyword"
                                 Width="250"/>

                        <Button Content="Search"
                                Width="100"
                                Margin="10,0"
                                Click="btnSearchMember_Click"/>

                    </StackPanel>

                    <DataGrid Grid.Row="1"
                          Margin="0,10"
                          x:Name="dgMembers"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="dgMembers_SelectionChanged">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ID"
                                    Binding="{Binding MemberId}"
                                    Width="60"/>

                            <DataGridTextColumn Header="Name"
                                    Binding="{Binding FullName}"
                                    Width="220"/>

                            <DataGridTextColumn Header="Phone"
                                    Binding="{Binding Phone}"
                                    Width="150"/>

                            <DataGridTextColumn Header="Email"
                                    Binding="{Binding Email}"
                                    Width="200"/>

                        </DataGrid.Columns>

                    </DataGrid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                Margin="0,10,0,0">

                        <TextBlock Text="Selected Member: "
                               FontWeight="Bold"/>

                        <TextBlock x:Name="txtSelectedMember"
                               Foreground="Blue"
                               FontWeight="SemiBold"/>
                    </StackPanel>

                </Grid>

            </GroupBox>

            <GroupBox Grid.Row="2"
                  Header="Books">

                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="35"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">

                        <TextBox x:Name="txtBookKeyword"
                             Width="250"/>

                        <Button Content="Search"
                            Width="100"
                            Margin="10,0"
                            Click="btnSearchBook_Click"/>

                        <Button Content="Add"
                            Width="100"
                            Margin="10,0"
                            Click="btnAdd_Click"/>

                    </StackPanel>

                    <DataGrid Grid.Row="1"
                          Margin="0,10"
                          x:Name="dgBooks"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ISBN"
                                            Binding="{Binding Isbn}"/>

                            <DataGridTextColumn Header="Title"
                                            Width="220"
                                            Binding="{Binding Title}"/>

                            <DataGridTextColumn Header="Category"
                                            Width="120"
                                            Binding="{Binding Category.CategoryName}"/>

                            <DataGridTextColumn Header="Author"
                                            Width="180"
                                            Binding="{Binding Author.AuthorName}"/>

                            <DataGridTextColumn Header="Available"
                                            Width="80"
                                            Binding="{Binding AvailableQuantity}"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </GroupBox>


            <GroupBox Grid.Row="3"
                  Header="Borrow List"
                  Margin="0,10,0,0">

                <DockPanel Margin="10">

                    <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10">

                        <Button Content="Remove"
                            Width="100"
                            Margin="0,0,10,0"
                            Click="btnRemove_Click"/>

                        <Button Content="Borrow"
                                Click="btnBorrow_Click"
                                Width="120"
                                Height="35"/>

                    </StackPanel>

                    <DataGrid x:Name="dgBorrow"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ISBN"
                                            Binding="{Binding Isbn}"/>

                            <DataGridTextColumn Header="Title"
                                            Width="220"
                                            Binding="{Binding Title}"/>

                            <DataGridTextColumn Header="Category"
                                            Width="120"
                                            Binding="{Binding Category.CategoryName}"/>

                            <DataGridTextColumn Header="Author"
                                            Width="180"
                                            Binding="{Binding Author.AuthorName}"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </DockPanel>

            </GroupBox>

        </Grid>
    </ScrollViewer>
</Page>
<Page x:Class="LibraryManagementProject.Views.ReturnBorrow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      d:Height="900"
d:Width="750"
      mc:Ignorable="d"
      Background="#F5F6FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="300"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,15">

            <StackPanel>

                <TextBlock Text="Return Book"
                           FontSize="28"
                           FontWeight="Bold"/>

                <TextBlock Text="Manage borrowed books and return process."
                           Foreground="Gray"
                           Margin="0,5,0,20"/>

                <DockPanel>

                    <TextBox x:Name="txtSearch"
                             Width="280"
                             Height="35"
                             VerticalContentAlignment="Center"
                             FontSize="14"
                             Margin="0,0,10,0"/>

                    <Button x:Name="btnSearch"
                            Click="btnSearch_Click"
                            Width="100"
                            Height="35"
                            Content="Search"/>

                </DockPanel>

            </StackPanel>

        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="15">

            <StackPanel>

                <TextBlock Text="Borrow Records"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <DataGrid x:Name="dgBorrowRecords"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          IsReadOnly="True"
                          Height="250">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Borrow Code"
                                            Binding="{Binding BorrowCode}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Member"
                                            Binding="{Binding Member.FullName}"
                                            Width="180"/>

                        <DataGridTextColumn Header="Borrow Date"
                                            Binding="{Binding BorrowDate}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Due Date"
                                            Binding="{Binding DueDate}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Books"
                                            Binding="{Binding TotalBooks}"
                                            Width="70"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>

            </StackPanel>

        </Border>

        <Border Grid.Row="3"
                Background="White"
                CornerRadius="10"
                Padding="15">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Borrow Details"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <DataGrid x:Name="dgBorrowDetails"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          SelectionMode="Extended"
                          Margin="0,10,0,10">

                    <DataGrid.Columns>

                        <DataGridCheckBoxColumn Width="50"/>

                        <DataGridTextColumn Header="Book"
                                            Binding="{Binding Book.Title}"
                                            Width="250"/>

                        <DataGridTextColumn Header="Quantity"
                                            Binding="{Binding Quantity}"
                                            Width="80"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="100"/>

                        <DataGridTextColumn Header="Return Date"
                                            Binding="{Binding ReturnDate}"
                                            Width="120"/>

                        <DataGridTextColumn Header="Fine"
                                            Binding="{Binding FineAmount}"
                                            Width="100"/>

                    </DataGrid.Columns>

                </DataGrid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button x:Name="btnReturnSelected"
                            Width="170"
                            Height="40"
                            Margin="0,0,10,0"
                            Content="Return Selected"
                            Click="btnReturnSelected_Click"/>

                    <Button x:Name="btnReturnAll"
                            Width="140"
                            Height="40"
                            FontWeight="Bold"
                            Content="Return All"
                            Click="btnReturnAll_Click"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>
</Page>
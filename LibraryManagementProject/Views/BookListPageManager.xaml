    <Page x:Class="LibraryManagementProject.Views.BookListPageManager"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          mc:Ignorable="d"
          Background="#ECF0F1">
        
        
        <Grid Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="900"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="300"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
            Grid.Column="0"
            Orientation="Horizontal"
            VerticalAlignment="Center">

            <TextBlock Text="Category:"
               VerticalAlignment="Center"
               Margin="0,0,10,0"/>

            <ComboBox x:Name="cbCategory"
              Width="200"
              SelectionChanged="cbCategory_SelectionChanged"/>

        </StackPanel>


        <ListView x:Name="lvBooks"
                  Grid.Column="0"
                  Grid.Row="1"
                  SelectionChanged="lvBooks_SelectionChanged"    
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Header="ID"
                                    Width="50"
                                    DisplayMemberBinding="{Binding BookId}"
                                    />

                        <GridViewColumn Header="Title"
                                    Width="220"
                                    DisplayMemberBinding="{Binding Title}"/>

                        <GridViewColumn Header="Author"
                                    Width="170"
                                    DisplayMemberBinding="{Binding Author.AuthorName}"/>

                        <GridViewColumn Header="Category"
                                    Width="140"
                                    DisplayMemberBinding="{Binding Category.CategoryName}"/>

                        <GridViewColumn Header="Price"
                                    Width="90"
                                    DisplayMemberBinding="{Binding Price}"/>

                        <GridViewColumn Header="Available"
                                    Width="80"
                                    DisplayMemberBinding="{Binding AvailableQuantity}"/>

                    <GridViewColumn Header="Status"
                                    Width="90"
                                    DisplayMemberBinding="{Binding StatusText}"/>

                </GridView>
                </ListView.View>

            </ListView>

            <StackPanel Grid.Column="1"
                        Grid.Row="1"
                    Margin="15,0,0,0"
                    VerticalAlignment="Top">

            <Button x:Name="btnAdd"
                    Content="Add Book"
                    Width="130"
                    Height="35"
                    Margin="0,0,0,10"
                    Click="btnAdd_Click"/>


            <Button x:Name="btnUpdate"
                    Content="Update"
                    Width="130"
                    Height="35"
                    Margin="0,0,0,10"
                    Click="btnUpdate_Click"/>

        </StackPanel>

        </Grid>
    </Page>

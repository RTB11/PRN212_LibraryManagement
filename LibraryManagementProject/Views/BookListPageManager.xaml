    <Page x:Class="LibraryManagementProject.Views.BookListPageManager"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          mc:Ignorable="d"
          Background="#ECF0F1">
        <Grid Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListView x:Name="lvBooks"
                  Grid.Column="0" 
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Header="ID"
                                    Width="50"
                                    DisplayMemberBinding="{Binding BookId}"/>

                        <GridViewColumn Header="Title"
                                    Width="220"
                                    DisplayMemberBinding="{Binding Title}"/>

                        <GridViewColumn Header="Author"
                                    Width="170"
                                    DisplayMemberBinding="{Binding Author.AuthorName}"/>

                        <GridViewColumn Header="Category"
                                    Width="140"
                                    DisplayMemberBinding="{Binding Category.CategoryName}"/>

                        <GridViewColumn Header="Price"
                                    Width="90"
                                    DisplayMemberBinding="{Binding Price}"/>

                        <GridViewColumn Header="Available"
                                    Width="80"
                                    DisplayMemberBinding="{Binding AvailableQuantity}"/>

                        <GridViewColumn Header="Status"
                                    Width="80"
                                    DisplayMemberBinding="{Binding IsActive}"/>

                    </GridView>
                </ListView.View>

            </ListView>

            <StackPanel Grid.Column="1"
                    Margin="15,0,0,0"
                    VerticalAlignment="Top">

                <Button x:Name="btnAdd"
                    Content="Add Book"
                    Width="130"
                    Height="35"
                    Margin="0,0,0,10"/>

                <Button x:Name="btnUpdate"
                    Content="Update"
                    Width="130"
                    Height="35"
                    Margin="0,0,0,10"/>

                <Button x:Name="btnDelete"
                    Content="Delete"
                    Width="130"
                    Height="35"
                    Margin="0,0,0,10"/>


            </StackPanel>

        </Grid>
    </Page>

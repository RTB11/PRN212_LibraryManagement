<Page x:Class="LibraryManagementProject.Views.BorrowHistory"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#F5F6FA"
      Title="Borrow History">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="300"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <Border Background="White"
                CornerRadius="10"
                Padding="20"
                Margin="0,0,0,15">

                <StackPanel>

                    <TextBlock Text="Borrow History"
                           FontSize="28"
                           FontWeight="Bold"/>


                    <TextBlock Text="View all borrowing records and status."
                           Foreground="Gray"
                           Margin="0,5,0,20"/>


                    <StackPanel Orientation="Horizontal">


                        <TextBox x:Name="txtSearch"
                             Width="250"
                             Height="35"
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"
                             ToolTip="Search Borrow Code or Member"/>


                        <ComboBox x:Name="cbStatus"
                              Width="150"
                              Height="35"
                              Margin="0,0,10,0">

                            <ComboBoxItem Content="All"
                                      IsSelected="True"/>

                            <ComboBoxItem Content="Borrowing"/>
                            <ComboBoxItem Content="Returned"/>

                        </ComboBox>


                        <Button x:Name="btnSearch"
                            Width="100"
                            Height="35"
                            Content="Search"/>


                        <Button x:Name="btnRefresh"
                            Width="100"
                            Height="35"
                            Margin="10,0,0,0"
                            Content="Refresh"/>

                    </StackPanel>

                </StackPanel>

            </Border>

            <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="15">


                <StackPanel>

                    <TextBlock Text="Borrow Records"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgBorrowHistory"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Height="240">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Borrow Code"
                                            Binding="{Binding BorrowCode}"
                                            Width="120"/>


                            <DataGridTextColumn Header="Member"
                                            Binding="{Binding Member.FullName}"
                                            Width="180"/>


                            <DataGridTextColumn Header="Borrow Date"
                                            Binding="{Binding BorrowDate}"
                                            Width="120"/>


                            <DataGridTextColumn Header="Due Date"
                                            Binding="{Binding DueDate}"
                                            Width="120"/>


                            <DataGridTextColumn Header="Total Books"
                                            Binding="{Binding TotalBooks}"
                                            Width="90"/>


                            <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="100"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </StackPanel>


            </Border>

            <Border Grid.Row="3"
                Background="White"
                CornerRadius="10"
                Padding="15">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Borrow Details"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgBorrowDetails"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">


                        <DataGrid.Columns>


                            <DataGridTextColumn Header="Book"
                                            Binding="{Binding Book.Title}"
                                            Width="250"/>


                            <DataGridTextColumn Header="Quantity"
                                            Binding="{Binding Quantity}"
                                            Width="80"/>


                            <DataGridTextColumn Header="Return Date"
                                            Binding="{Binding ReturnDate}"
                                            Width="120"/>


                            <DataGridTextColumn Header="Fine Amount"
                                            Binding="{Binding FineAmount}"
                                            Width="100"/>


                            <DataGridTextColumn Header="Status"
                                            Binding="{Binding Status}"
                                            Width="120"/>


                        </DataGrid.Columns>


                    </DataGrid>


                </Grid>


            </Border>


        </Grid>
        
    </ScrollViewer>

</Page>
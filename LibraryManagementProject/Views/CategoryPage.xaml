<Page x:Class="LibraryManagementProject.Views.CategoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#ECF0F1">


    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <ListView x:Name="lvCategories"
                  Grid.Column="0"
                  Margin="0,0,15,0"
                  SelectionChanged="lvCategories_SelectionChanged">

            <ListView.View>

                <GridView>

                    <GridViewColumn Header="ID"
                                    Width="60"
                                    DisplayMemberBinding="{Binding CategoryId}"/>
                    <GridViewColumn Header="Category Name"
                                    Width="200"
                                    DisplayMemberBinding="{Binding CategoryName}"/>
                    <GridViewColumn Header="Description"
                                    Width="250"
                                    DisplayMemberBinding="{Binding Description}"/>
                </GridView>

            </ListView.View>

        </ListView>
        
        <Border Grid.Column="1"
                Background="White"
                Padding="15">


            <StackPanel>


                <Label Content="Category Controller"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>



                <Label Content="Category Name"
                       Margin="0,20,0,5"/>


                <TextBox x:Name="txtCategoryName"
                         Height="30"/>



                <Label Content="Description"
                       Margin="0,10,0,5"/>


                <TextBox x:Name="txtDescription"
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"/>



                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,25,0,0">


                    <Button x:Name="btnSave"
                            Content="Save"
                            Width="70"
                            Click="btnSave_Click"/>


                    <Button x:Name="btnAdd"
                            Content="Add"
                            Width="70"
                            Margin="10,0,0,0"
                            Click="btnAdd_Click"/>


                    <Button x:Name="btnDelete"
                            Content="Delete"
                            Width="70"
                            Margin="10,0,0,0"
                            Click="btnDelete_Click"/>


                </StackPanel>


            </StackPanel>


        </Border>


    </Grid>

</Page>
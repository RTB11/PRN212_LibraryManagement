<Window x:Class="LibraryManagementProject.Views.LibrarianFrame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryManagementProject.Views"
        mc:Ignorable="d"
        Title="LibrarianDashboard" Height="450" Width="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#1565C0">

            <TextBlock Text="LIBRARY MANAGEMENT SYSTEM"
                       Foreground="White"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>

        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Background="#1565C0">

                <Button Click="Dashboard_Click" 
                        Content="Dashboard"
                        Height="30" 
                        Margin="5"/>
                
                <Button Click="Borrow_Click" 
                        Content="Borrow Book" 
                        Height="30" 
                        Margin="5"/>

                <Button Click="Return_Click"  
                        Content="Return Book" 
                        Height="30" 
                        Margin="5"/>

                <Button Click="BorrowHistory_Click"
                        Content="Borrow History"
                        Height="30"
                        Margin="5"/>

                <Button Click="PasswordChange_Click" 
                        Content="Change Password" 
                        Height="30" 
                        Margin="5"/>

                <Button Click="Logout_Click" 
                        Content="Logout" 
                        Height="30" 
                        Margin="5"/>

            </StackPanel>

            <Frame x:Name="MainFrame"
                   Grid.Column="1"
                   NavigationUIVisibility="Hidden"/>

        </Grid>

    </Grid>

</Window>

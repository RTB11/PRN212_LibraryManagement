<Window x:Class="LibraryManagementProject.Views.ChangePassword"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LibraryManagementProject.Views"
      mc:Ignorable="d" 
      d:DesignHeight="300" d:DesignWidth="400"
      Background="#F5F6FA"
      Title="ChangePassword">

    <StackPanel Width="350"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

        <TextBlock Text="Change Password"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,0,20"/>

        <TextBlock Text="Old Password"/>
        <PasswordBox x:Name="txtOldPassword"
                 Margin="0,5,0,15"/>

        <TextBlock Text="New Password"/>
        <PasswordBox x:Name="txtNewPassword"
                 Margin="0,5,0,15"/>

        <TextBlock Text="Confirm Password"/>
        <PasswordBox x:Name="txtConfirmPassword"
                 Margin="0,5,0,20"/>

        <Button Content="Change Password"
            Height="40"
            Click="btnChangePassword_Click"/>

    </StackPanel>
</Window>
